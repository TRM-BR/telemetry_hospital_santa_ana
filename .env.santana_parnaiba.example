# =====================================================================
# Hospital Santa Ana — Santana do Parnaíba
# Copie para .env.santana_parnaiba e preencha.
# NUNCA commitar este arquivo preenchido. chmod 600.
# =====================================================================

# ─── Identificação da instância ──────────────────────────────────────
TELEMETRY_CLIENT_SLUG=santana_parnaiba
TELEMETRY_ENV=prod                          # prod | hml | dev

# ─── PostgreSQL ───────────────────────────────────────────────────────
TELEMETRY_DB_HOST=<ip_privado_vps>
TELEMETRY_DB_PORT=5432
TELEMETRY_DB_NAME=telemetry_santana_parnaiba_prod
TELEMETRY_DB_USER=telemetry_app
TELEMETRY_DB_PASSWORD=                      # gerar com openssl rand -hex 32
TELEMETRY_DB_POOL_SIZE=5
TELEMETRY_DB_POOL_MAX_OVERFLOW=2

# ─── MQTT Broker ──────────────────────────────────────────────────────
TELEMETRY_MQTT_HOST=<mqtt_host>
TELEMETRY_MQTT_PORT=8883
TELEMETRY_MQTT_TLS=true
TELEMETRY_MQTT_CA_CERT_PATH=/etc/telemetry/certs/ca.crt
TELEMETRY_MQTT_USERNAME=telemetry_santana_parnaiba_bridge
TELEMETRY_MQTT_PASSWORD=                    # gerar; nunca commitar
TELEMETRY_MQTT_CLIENT_ID=telemetry-bridge-santana_parnaiba
TELEMETRY_MQTT_KEEPALIVE=30
# NÃO definir TELEMETRY_MQTT_TOPIC_PREFIX aqui — telemetry_topics vem do YAML

# ─── API / FastAPI ───────────────────────────────────────────────────
TELEMETRY_API_HOST=0.0.0.0
TELEMETRY_API_PORT=5003
TELEMETRY_API_SECRET_KEY=                   # gerar com openssl rand -hex 32
TELEMETRY_API_TOKEN_MAX_AGE_SECONDS=43200
TELEMETRY_API_CORS_ORIGINS=https://telemetria.santanaparnaiba.sp.gov.br

# --- Frontend / Vite --------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_ENABLE_MOCKS=false                     # true = usa mocks no frontend

# ─── Workers ─────────────────────────────────────────────────────────
TELEMETRY_WORKER_BATCH_SIZE=50
TELEMETRY_WORKER_IDLE_SECONDS=5
TELEMETRY_WORKER_STUCK_THRESHOLD_SECONDS=300
TELEMETRY_WORKER_MAX_ATTEMPTS=5
TELEMETRY_WORKER_ALERT_INTERVAL_SECONDS=30

# ─── Admin inicial ───────────────────────────────────────────────────
TELEMETRY_ADMIN_INITIAL_PASSWORD=           # senha do admin inicial; trocar após 1º login

# ─── Telegram (alertas críticos) ─────────────────────────────────────
TELEMETRY_TELEGRAM_ALERTS_ENABLED=false
TELEMETRY_TELEGRAM_BOT_TOKEN=
TELEMETRY_TELEGRAM_BOT_USERNAME=
TELEMETRY_TELEGRAM_WEBHOOK_SECRET=

# ─── Logging ─────────────────────────────────────────────────────────
TELEMETRY_LOG_LEVEL=INFO
TELEMETRY_LOG_FORMAT=json

# ─── Serviços NÃO usados no hospital (analógico, sem calibração) ──────
# NÃO subir telemetry-worker-calib neste ambiente.
