# =====================================================================
# telemetry — variáveis de ambiente por instância (prefeitura)
# Copie este arquivo para .env.<slug> (ex.: .env.barueri) e preencha.
# NUNCA commitar .env real. Permissão obrigatória: chmod 600.
# =====================================================================

# ─── Identificação da instância ──────────────────────────────────────
TELEMETRY_CLIENT_SLUG=barueri
TELEMETRY_ENV=prod                       # prod | hml | dev
TELEMETRY_TIMEZONE=America/Sao_Paulo

# ─── PostgreSQL (VPS 3, rede privada) ────────────────────────────────
TELEMETRY_DB_HOST=10.0.0.3               # IP privado da VPS 3
TELEMETRY_DB_PORT=5432
TELEMETRY_DB_NAME=telemetry_barueri_prod
TELEMETRY_DB_USER=telemetry_app
TELEMETRY_DB_PASSWORD=                   # gerar; nunca commitar
TELEMETRY_DB_POOL_SIZE=5
TELEMETRY_DB_POOL_MAX_OVERFLOW=2

# ─── MQTT Broker (VPS 1) ─────────────────────────────────────────────
TELEMETRY_MQTT_HOST=mqtt.example.com
TELEMETRY_MQTT_PORT=8883
TELEMETRY_MQTT_TLS=true
TELEMETRY_MQTT_CA_CERT_PATH=/etc/telemetry/certs/ca.crt
TELEMETRY_MQTT_USERNAME=telemetry_barueri_bridge
TELEMETRY_MQTT_PASSWORD=                 # gerar; nunca commitar
TELEMETRY_MQTT_CLIENT_ID=telemetry-bridge-barueri
TELEMETRY_MQTT_KEEPALIVE=30
# Padrão de subscrição. Legado: SN50/data/#  Novo: telemetry/<slug>/devices/+/data
TELEMETRY_MQTT_TOPIC_PREFIX=SN50/data/#

# ─── API / FastAPI ───────────────────────────────────────────────────
TELEMETRY_API_HOST=0.0.0.0
TELEMETRY_API_PORT=5002
TELEMETRY_API_SECRET_KEY=                # gerar; nunca commitar
TELEMETRY_API_TOKEN_MAX_AGE_SECONDS=43200
TELEMETRY_API_CORS_ORIGINS=https://telemetria.barueri.gov.br

# ─── Workers (parse / derive / alert) ────────────────────────────────
TELEMETRY_WORKER_BATCH_SIZE=50
TELEMETRY_WORKER_IDLE_SECONDS=5
TELEMETRY_WORKER_STUCK_THRESHOLD_SECONDS=300
TELEMETRY_WORKER_MAX_ATTEMPTS=5
TELEMETRY_WORKER_BACKOFF_SCHEDULE=60,300,900,3600,21600

# ─── Logging ─────────────────────────────────────────────────────────
TELEMETRY_LOG_LEVEL=INFO
TELEMETRY_LOG_FORMAT=json
